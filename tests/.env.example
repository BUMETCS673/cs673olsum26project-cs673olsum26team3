# Copy this file to .env (git-ignored) and fill in your credentials.
# Used by conftest.py for login and backend health checks.

TEST_USERNAME=your_username_here
TEST_PASSWORD=your_password_here

# Optional overrides (defaults shown)
# BASE_URL=http://localhost:5173
# BACKEND_URL=http://localhost:5001

# Set to true to skip the real backend and always use the JS fetch mock.
# Useful locally when you don't have a working OPENAI_API_KEY in backend/.env.
# Leave unset (or false) in CI so the real backend is exercised.
# FORCE_MOCK=true
